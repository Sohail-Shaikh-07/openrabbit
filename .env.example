# Copy this file to .env and fill in the values OpenRabbit needs at runtime.
# Anything in .env is loaded by docker compose into the openrabbit service.

# --------- GitHub credentials ---------
# Personal access token with `repo` scope. Stays on your machine.
GITHUB_TOKEN=

# --------- OpenRabbit overrides ---------
# Each variable below overrides the matching key in .codereviewer/config.yml.
# Format: OPENRABBIT_<section>__<field>=<value>

# Override how often the polling service checks GitHub for new pull requests.
# OPENRABBIT_POLLING__INTERVAL_SECONDS=60

# Force a specific GitHub token at runtime instead of using GITHUB_TOKEN.
# OPENRABBIT_GITHUB__TOKEN=

# Pick a different review model than the project default.
# OPENRABBIT_MODEL__MODEL_NAME=openrabbit-reviewer-v1

# --------- Workspace ---------
# Absolute or relative path to the repository OpenRabbit should review.
# Mounted read-only at /workspace inside the container.
# OPENRABBIT_WORKSPACE=./
