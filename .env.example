# Optional Docker Compose environment for OpenRabbit.
#
# Copy to .env when you want compose to pass these values into the
# openrabbit container. Do not commit real tokens.

GITHUB_TOKEN=
OPENRABBIT_GITHUB__TOKEN=

# Optional model provider keys. Leave blank when using local Ollama.
OPENAI_API_KEY=
OPENAI_COMPATIBLE_API_KEY=

# Absolute path to the repository that OpenRabbit should review when using
# the containerized CLI.
OPENRABBIT_WORKSPACE=./
